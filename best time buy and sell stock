class Solution:
    def maxProfit(self, prices: List[int]) -> int:
        
        min_price = float('inf')
        max_profit = 0
        
        for price in prices:
            if price < min_price:
                min_price = price   # Update minimum price
            
            profit = price - min_price
            
            if profit > max_profit:
                max_profit = profit  # Update maximum profit
        
        return max_profit
        
        
